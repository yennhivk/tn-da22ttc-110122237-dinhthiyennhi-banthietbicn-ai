                const data = await response.json();
                
                if (data.success) {
                    alert('âœ… ÄÃ£ xÃ³a mÃ¡y POS');
                    loadPOSMachines();
                } else {
                    alert('âŒ ' + data.message);
                }
            } catch (error) {
                console.error('Delete POS error:', error);
                alert('âŒ CÃ³ lá»—i xáº£y ra');
            }
        }

        async function testPOS(id) {
            alert('Chá»©c nÄƒng test mÃ¡y POS Ä‘ang phÃ¡t triá»ƒn');
