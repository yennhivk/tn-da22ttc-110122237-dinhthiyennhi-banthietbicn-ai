                'offline': { color: 'orange', icon: 'âš ï¸', text: 'Offline' },
                'maintenance': { color: 'red', icon: 'ðŸ”§', text: 'Báº£o trÃ¬' }
            };
            
            const html = allPOSMachines.map(pos => {
                const status = statusConfig[pos.trang_thai] || statusConfig['offline'];
                const employeeCount = pos.nhan_vien_ids ? pos.nhan_vien_ids.split(',').length : 0;
                
                return `
                    <div class="bg-white rounded-xl shadow-lg hover:shadow-xl transition-all border-2 border-${status.color}-200">
                        <div class="bg-gradient-to-br from-${status.color}-500 to-${status.color}-600 p-6 text-white rounded-t-xl">
                            <div class="flex items-center justify-between mb-4">
                                <div class="text-5xl">ðŸ’³</div>
                                <span class="bg-white/20 px-3 py-1 rounded-full text-sm font-medium">${status.icon} ${status.text}</span>
                            </div>
                            <h4 class="text-2xl font-bold mb-1">${pos.ten_may}</h4>
                            <p class="text-sm opacity-90">${pos.ma_may}</p>
                        </div>
                        
                        <div class="p-6 space-y-4">
                            ${pos.vi_tri ? `
                                <div class="flex items-start gap-2">
                                    <span class="text-gray-500">ðŸ“</span>
                                    <div class="flex-1">
                                        <p class="text-xs text-gray-500">Vá»‹ trÃ­:</p>
                                        <p class="text-sm font-medium text-gray-700">${pos.vi_tri}</p>
                                    </div>
                                </div>
                            ` : ''}
                            
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <p class="text-xs text-gray-500 mb-1">MÃ¡y in:</p>
                                    <p class="text-sm font-medium ${pos.may_in ? 'text-green-600' : 'text-gray-400'}">
                                        ${pos.may_in ? 'ðŸ–¨ï¸ ÄÃ£ káº¿t ná»‘i' : 'âŒ ChÆ°a káº¿t ná»‘i'}
                                    </p>
                                </div>
                                <div>
                                    <p class="text-xs text-gray-500 mb-1">MÃ¡y quÃ©t:</p>
                                    <p class="text-sm font-medium ${pos.may_quet ? 'text-green-600' : 'text-gray-400'}">
                                        ${pos.may_quet ? 'ðŸ“· ÄÃ£ káº¿t ná»‘i' : 'âŒ ChÆ°a káº¿t ná»‘i'}
                                    </p>
                                </div>
                            </div>
                            
                            <div class="pt-4 border-t">
                                <p class="text-xs text-gray-500 mb-2">NhÃ¢n viÃªn Ä‘Æ°á»£c phÃ©p sá»­ dá»¥ng:</p>
                                <p class="text-sm font-bold text-blue-600">${employeeCount} nhÃ¢n viÃªn</p>
                            </div>
                            
                            <div class="flex gap-2 pt-2">
                                <button onclick="editPOS(${pos.ma_pos})" class="flex-1 bg-blue-100 hover:bg-blue-200 text-blue-700 py-2 rounded-lg font-semibold text-sm">
                                    âœï¸ Sá»­a
                                </button>
                                <button onclick="testPOS(${pos.ma_pos})" class="flex-1 bg-green-100 hover:bg-green-200 text-green-700 py-2 rounded-lg font-semibold text-sm">
                                    ðŸ§ª Test
                                </button>
                                <button onclick="deletePOS(${pos.ma_pos})" class="bg-red-100 hover:bg-red-200 text-red-700 px-4 py-2 rounded-lg font-semibold text-sm">
                                    ðŸ—‘ï¸
                                </button>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
            
            container.innerHTML = html;
        }

        function renderPOSTransactions(transactions) {
            const tbody = document.getElementById('pos-transactions-table');
            if (!tbody) return;
            
            if (transactions.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="6" class="text-center py-8 text-gray-500">
                            <div class="text-4xl mb-2">ðŸ’³</div>
                            ChÆ°a cÃ³ giao dá»‹ch nÃ o
                        </td>
                    </tr>
                `;
                return;
            }
            
            const html = transactions.map(t => {
                const typeLabels = {
                    'sale': 'ðŸ’° BÃ¡n hÃ ng',
                    'refund': 'â†©ï¸ HoÃ n tráº£',
                    'void': 'âŒ Há»§y',
                    'test': 'ðŸ§ª Test'
                };
                
                return `
                    <tr class="border-b hover:bg-gray-50">
                        <td class="px-4 py-3">${new Date(t.thoi_gian).toLocaleString('vi-VN')}</td>
                        <td class="px-4 py-3 font-medium">${t.ten_may}</td>
                        <td class="px-4 py-3">${t.nhan_vien || '-'}</td>
                        <td class="px-4 py-3">${typeLabels[t.loai_giao_dich] || t.loai_giao_dich}</td>
                        <td class="px-4 py-3 text-right font-bold text-green-600">${formatPrice(t.so_tien)}</td>
                        <td class="px-4 py-3 text-center">
                            <button onclick="viewPOSTransaction(${t.ma_giao_dich})" class="text-blue-600 hover:text-blue-700 font-medium text-sm">Chi tiáº¿t</button>
                        </td>
                    </tr>
                `;
            }).join('');
            
            tbody.innerHTML = html;
        }

        function updatePOSFilter() {
            const select = document.getElementById('pos-filter');
            if (!select) return;
            
            const options = allPOSMachines.map(pos => 
                `<option value="${pos.ma_pos}">${pos.ten_may} (${pos.ma_may})</option>`
            ).join('');
            
            select.innerHTML = '<option value="">Táº¥t cáº£ mÃ¡y POS</option>' + options;
        }

        async function filterPOSTransactions() {
            const posId = document.getElementById('pos-filter').value;
            const date = document.getElementById('pos-date-filter').value;
            
            try {
                const params = new URLSearchParams();
                if (posId) params.append('posId', posId);
                if (date) params.append('date', date);
                
                const response = await fetch(`${API_URL}/admin/pos-transactions?${params}`, {
                    headers: { 'Authorization': `Bearer ${adminToken}` }
                });
                const data = await response.json();
                
                if (data.success) {
                    renderPOSTransactions(data.data.transactions || []);
                }
            } catch (error) {
                console.error('Filter POS transactions error:', error);
            }
        }

        function openPOSModal(id = null) {
            const modal = document.getElementById('pos-modal');
            const form = document.getElementById('pos-form');
            const title = document.getElementById('pos-modal-title');
            
            form.reset();
            renderEmployeesList();
            
            if (id) {
                // Edit mode
                const pos = allPOSMachines.find(p => p.ma_pos === id);
                if (pos) {
                    title.textContent = 'âœï¸ Sá»­a mÃ¡y POS';
                    document.getElementById('pos-id').value = pos.ma_pos;
                    document.getElementById('pos-code').value = pos.ma_may;
                    document.getElementById('pos-name').value = pos.ten_may;
                    document.getElementById('pos-location').value = pos.vi_tri || '';
                    document.getElementById('pos-status').value = pos.trang_thai;
                    document.getElementById('pos-printer').value = pos.may_in || '';
                    document.getElementById('pos-printer-port').value = pos.cong_may_in || '';
                    document.getElementById('pos-scanner').value = pos.may_quet || '';
                    document.getElementById('pos-scanner-port').value = pos.cong_may_quet || '';
                    document.getElementById('pos-notes').value = pos.ghi_chu || '';
                    
                    // Check employees
                    if (pos.nhan_vien_ids) {
                        const employeeIds = pos.nhan_vien_ids.split(',');
                        employeeIds.forEach(id => {
                            const checkbox = document.getElementById(`emp-${id}`);
                            if (checkbox) checkbox.checked = true;
                        });
                    }
                }
            } else {
                // Add mode
                title.textContent = 'âž• ThÃªm mÃ¡y POS má»›i';
            }
            
            modal.classList.add('active');
        }

        function closePOSModal() {
            document.getElementById('pos-modal').classList.remove('active');
        }

        function renderEmployeesList() {
            const container = document.getElementById('pos-employees-list');
            if (!container) return;
            
            if (allEmployees.length === 0) {
                container.innerHTML = '<p class="text-gray-500 text-sm">ChÆ°a cÃ³ nhÃ¢n viÃªn nÃ o</p>';
                return;
            }
            
            const html = allEmployees.map(emp => `
                <label class="flex items-center gap-2 p-2 hover:bg-gray-50 rounded cursor-pointer">
                    <input type="checkbox" id="emp-${emp.ma_nhan_vien}" value="${emp.ma_nhan_vien}" class="w-4 h-4">
                    <span class="text-sm">${emp.ho_ten} - ${emp.chuc_vu || 'NhÃ¢n viÃªn'}</span>
                </label>
            `).join('');
            
            container.innerHTML = html;
        }

        function editPOS(id) {
            openPOSModal(id);
        }

        async function deletePOS(id) {
            if (!confirm('Báº¡n cÃ³ cháº¯c muá»‘n xÃ³a mÃ¡y POS nÃ y?')) return;
            
            try {
