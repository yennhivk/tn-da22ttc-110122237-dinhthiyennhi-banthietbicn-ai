                    `;
                    
                    document.body.insertAdjacentHTML('beforeend', detailHTML);
                    console.log('Modal inserted successfully');
                } else {
                    alert('KhÃ´ng thá»ƒ láº¥y thÃ´ng tin khÃ¡ch hÃ ng: ' + (d.message || 'Lá»—i khÃ´ng xÃ¡c Ä‘á»‹nh'));
