                'COD': 'Thanh toÃ¡n khi nháº­n hÃ ng (COD)',
                'Momo': 'VÃ­ MoMo',
                'Ngan_Hang': 'Chuyá»ƒn khoáº£n ngÃ¢n hÃ ng',
                'ZaloPay': 'ZaloPay'
            }[order.phuong_thuc_thanh_toan] || order.phuong_thuc_thanh_toan;
            
            // Render chi tiáº¿t sáº£n pháº©m
            let productsHtml = '';
            if (order.chi_tiet && order.chi_tiet.length > 0) {
