            } catch (error) {
                console.error('Create pre-order error:', error);
                alert('âŒ CÃ³ lá»—i xáº£y ra');
            }
        });

        // ==================== POS MACHINES FUNCTIONS ====================
        
        let allPOSMachines = [];
        let allEmployees = [];

        async function loadPOSMachines() {
            try {
                const response = await fetch(`${API_URL}/admin/pos-machines`, {
                    headers: { 'Authorization': `Bearer ${adminToken}` }
                });
                const data = await response.json();
                
                if (data.success) {
                    allPOSMachines = data.data.machines || [];
                    allEmployees = data.data.employees || [];
                    updatePOSStats(data.data.stats);
                    renderPOSMachines();
                    renderPOSTransactions(data.data.transactions || []);
                    updatePOSFilter();
                }
            } catch (error) {
                console.error('Load POS machines error:', error);
            }
        }

        function updatePOSStats(stats) {
            document.getElementById('pos-total').textContent = stats.total || 0;
            document.getElementById('pos-active').textContent = stats.active || 0;
            document.getElementById('pos-offline').textContent = stats.offline || 0;
            document.getElementById('pos-transactions-today').textContent = stats.transactionsToday || 0;
        }

        function renderPOSMachines() {
