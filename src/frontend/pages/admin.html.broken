        // ==================== FINANCIAL REPORT FUNCTIONS ====================
        
        let financialCharts = {
            trend: null,
            expense: null
        };

        async function loadFinancialReport() {
            const period = document.getElementById('financial-period').value;
            const startDate = document.getElementById('financial-start-date').value;
            const endDate = document.getElementById('financial-end-date').value;
            
            // Show/hide custom date range
            if (period === 'custom') {
                document.getElementById('custom-date-range').classList.remove('hidden');
                if (!startDate || !endDate) return;
            } else {
                document.getElementById('custom-date-range').classList.add('hidden');
            }
            
            try {
                // Load financial summary
                const params = new URLSearchParams({ period });
                if (period === 'custom' && startDate && endDate) {
                    params.append('startDate', startDate);
                    params.append('endDate', endDate);
                }
                
                const response = await fetch(`${API_URL}/admin/financial-report?${params}`, {
                    headers: { 'Authorization': `Bearer ${adminToken}` }
                });
                const data = await response.json();
                
                if (data.success) {
                    updateFinancialSummary(data.data);
                    updateFinancialCharts(data.data);
                    updateDebtInfo(data.data);
                    updateKPIs(data.data);
                    updateTransactionsTable(data.data.transactions || []);
                }
            } catch (error) {
                console.error('Load financial report error:', error);
                showFinancialError();
            }
        }

        function updateFinancialSummary(data) {
            const summary = data.summary || {};
            
            // Update main cards
            document.getElementById('fin-total-revenue').textContent = formatPrice(summary.totalRevenue || 0);
            document.getElementById('fin-total-expense').textContent = formatPrice(summary.totalExpense || 0);
            document.getElementById('fin-profit').textContent = formatPrice(summary.profit || 0);
            document.getElementById('fin-profit-margin').textContent = (summary.profitMargin || 0).toFixed(1) + '%';
            
            // Update trends
            updateTrendIndicator('fin-revenue-trend', summary.revenueTrend || 0);
            updateTrendIndicator('fin-expense-trend', summary.expenseTrend || 0);
            updateTrendIndicator('fin-profit-trend', summary.profitTrend || 0);
            updateTrendIndicator('fin-margin-trend', summary.marginTrend || 0);
        }

        function updateTrendIndicator(elementId, trend) {
            const element = document.getElementById(elementId);
            const isPositive = trend >= 0;
            const arrow = isPositive ? 'â†—' : 'â†˜';
            const sign = isPositive ? '+' : '';
            
            element.innerHTML = `<span>${arrow}</span> <span>${sign}${trend.toFixed(1)}%</span>`;
        }

        function updateFinancialCharts(data) {
            // Destroy existing charts
            if (financialCharts.trend) financialCharts.trend.destroy();
            if (financialCharts.expense) financialCharts.expense.destroy();
            
            // Trend Chart
            const trendCtx = document.getElementById('financial-trend-chart').getContext('2d');
            financialCharts.trend = new Chart(trendCtx, {
                type: 'line',
                data: {
                    labels: data.trendData?.labels || [],
                    datasets: [
                        {
                            label: 'Doanh thu',
                            data: data.trendData?.revenue || [],
                            borderColor: '#3b82f6',
                            backgroundColor: 'rgba(59, 130, 246, 0.1)',
                            tension: 0.4,
                            fill: true
                        },
                        {
                            label: 'Chi phÃ­',
                            data: data.trendData?.expense || [],
                            borderColor: '#ef4444',
                            backgroundColor: 'rgba(239, 68, 68, 0.1)',
                            tension: 0.4,
                            fill: true
                        },
                        {
                            label: 'Lá»£i nhuáº­n',
                            data: data.trendData?.profit || [],
                            borderColor: '#10b981',
                            backgroundColor: 'rgba(16, 185, 129, 0.1)',
                            tension: 0.4,
                            fill: true
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top' },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.dataset.label + ': ' + formatPrice(context.parsed.y);
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return formatPrice(value);
                                }
                            }
                        }
                    }
                }
            });
            
            // Expense Structure Chart
            const expenseCtx = document.getElementById('expense-structure-chart').getContext('2d');
            financialCharts.expense = new Chart(expenseCtx, {
                type: 'doughnut',
                data: {
                    labels: data.expenseStructure?.labels || [],
                    datasets: [{
                        data: data.expenseStructure?.values || [],
                        backgroundColor: [
                            '#ef4444', '#f59e0b', '#10b981', '#3b82f6', 
                            '#8b5cf6', '#ec4899', '#14b8a6', '#f97316'
                        ]
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'right' },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const label = context.label || '';
                                    const value = formatPrice(context.parsed);
                                    const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                    const percent = ((context.parsed / total) * 100).toFixed(1);
                                    return `${label}: ${value} (${percent}%)`;
                                }
                            }
                        }
                    }
                }
            });
        }

        function updateDebtInfo(data) {
            const debt = data.debt || {};
            
            // Customer debt
            document.getElementById('customer-debt-total').textContent = formatPrice(debt.customerTotal || 0);
            document.getElementById('customer-debt-overdue').textContent = formatPrice(debt.customerOverdue || 0);
            document.getElementById('customer-debt-current').textContent = formatPrice(debt.customerCurrent || 0);
            
            // Supplier debt
            document.getElementById('supplier-debt-total').textContent = formatPrice(debt.supplierTotal || 0);
            document.getElementById('supplier-debt-overdue').textContent = formatPrice(debt.supplierOverdue || 0);
            document.getElementById('supplier-debt-current').textContent = formatPrice(debt.supplierCurrent || 0);
            
            // Top debtors
            renderTopDebts('top-customer-debts', debt.topCustomers || []);
            renderTopDebts('top-supplier-debts', debt.topSuppliers || []);
        }

        function renderTopDebts(containerId, debts) {
            const container = document.getElementById(containerId);
            if (!container) return;
            
            if (debts.length === 0) {
                container.innerHTML = '<p class="text-sm text-gray-400 text-center py-2">KhÃ´ng cÃ³ dá»¯ liá»‡u</p>';
                return;
            }
            
            const html = debts.slice(0, 5).map((debt, index) => `
                <div class="flex items-center justify-between p-2 bg-gray-50 rounded hover:bg-gray-100">
                    <div class="flex items-center gap-2">
                        <span class="text-xs font-bold text-gray-400">#${index + 1}</span>
                        <span class="text-sm font-medium text-gray-700">${debt.name}</span>
                    </div>
                    <span class="text-sm font-bold text-red-600">${formatPrice(debt.amount)}</span>
                </div>
            `).join('');
            
            container.innerHTML = html;
        }

        function updateKPIs(data) {
            const kpi = data.kpi || {};
            
            document.getElementById('kpi-roi').textContent = (kpi.roi || 0).toFixed(1) + '%';
            document.getElementById('kpi-inventory-turnover').textContent = (kpi.inventoryTurnover || 0).toFixed(1);
            document.getElementById('kpi-avg-order').textContent = formatPrice(kpi.avgOrderValue || 0);
            document.getElementById('kpi-completion-rate').textContent = (kpi.completionRate || 0).toFixed(1) + '%';
        }

        function updateTransactionsTable(transactions) {
            const tbody = document.getElementById('transactions-table');
            if (!tbody) return;
            
            if (transactions.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="6" class="text-center py-8 text-gray-500">
                            <div class="text-4xl mb-2">ðŸ“Š</div>
                            KhÃ´ng cÃ³ giao dá»‹ch nÃ o
                        </td>
                    </tr>
                `;
                document.getElementById('transaction-count').textContent = '0';
                return;
            }
            
            const html = transactions.map(t => {
                const typeClass = t.type === 'revenue' ? 'text-green-600' : 'text-red-600';
                const typeIcon = t.type === 'revenue' ? 'ðŸ’°' : 'ðŸ’¸';
                const statusClass = t.status === 'completed' ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700';
                const statusText = t.status === 'completed' ? 'HoÃ n thÃ nh' : 'Chá» xá»­ lÃ½';
                
                return `
                    <tr class="border-b hover:bg-gray-50">
                        <td class="px-4 py-3">${new Date(t.date).toLocaleDateString('vi-VN')}</td>
                        <td class="px-4 py-3">
                            <span class="inline-flex items-center gap-1">
                                ${typeIcon} <span class="${typeClass} font-medium">${t.type === 'revenue' ? 'Doanh thu' : 'Chi phÃ­'}</span>
                            </span>
                        </td>
                        <td class="px-4 py-3 text-gray-700">${t.description}</td>
                        <td class="px-4 py-3 text-right font-bold ${typeClass}">${formatPrice(t.amount)}</td>
                        <td class="px-4 py-3 text-center">
                            <span class="px-3 py-1 rounded-full text-xs font-medium ${statusClass}">${statusText}</span>
                        </td>
                        <td class="px-4 py-3 text-center">
                            <button onclick="viewTransactionDetail(${t.id})" class="text-blue-600 hover:text-blue-700 font-medium text-sm">Chi tiáº¿t</button>
                        </td>
                    </tr>
                `;
            }).join('');
            
            tbody.innerHTML = html;
            document.getElementById('transaction-count').textContent = transactions.length;
        }

        function filterTransactions() {
            loadFinancialReport();
        }

        function searchTransactions() {
            const searchTerm = document.getElementById('transaction-search').value.toLowerCase();
            const rows = document.querySelectorAll('#transactions-table tr');
            
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(searchTerm) ? '' : 'none';
            });
        }

        function loadMoreTransactions() {
            alert('Chá»©c nÄƒng Ä‘ang phÃ¡t triá»ƒn');
        }

        function showDebtDetail(type) {
            alert(`Xem chi tiáº¿t cÃ´ng ná»£ ${type === 'customer' ? 'khÃ¡ch hÃ ng' : 'nhÃ  cung cáº¥p'}`);
        }

        function viewTransactionDetail(id) {
            alert(`Xem chi tiáº¿t giao dá»‹ch #${id}`);
        }

        async function exportFinancialReport(format) {
            const period = document.getElementById('financial-period').value;
            const startDate = document.getElementById('financial-start-date').value;
            const endDate = document.getElementById('financial-end-date').value;
            
            try {
                const params = new URLSearchParams({ period, format });
                if (period === 'custom' && startDate && endDate) {
                    params.append('startDate', startDate);
                    params.append('endDate', endDate);
                }
                
                const response = await fetch(`${API_URL}/admin/financial-report/export?${params}`, {
                    headers: { 'Authorization': `Bearer ${adminToken}` }
                });
                
                if (response.ok) {
                    const blob = await response.blob();
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `bao-cao-tai-chinh-${new Date().getTime()}.${format}`;
                    document.body.appendChild(a);
                    a.click();
                    window.URL.revokeObjectURL(url);
                    document.body.removeChild(a);
                    
                    alert(`âœ… ÄÃ£ xuáº¥t bÃ¡o cÃ¡o ${format.toUpperCase()} thÃ nh cÃ´ng!`);
                } else {
                    throw new Error('Export failed');
                }
            } catch (error) {
                console.error('Export error:', error);
                alert('âŒ CÃ³ lá»—i khi xuáº¥t bÃ¡o cÃ¡o. Vui lÃ²ng thá»­ láº¡i!');
            }
        }

        function showFinancialError() {
            document.getElementById('fin-total-revenue').textContent = '0Ä‘';
            document.getElementById('fin-total-expense').textContent = '0Ä‘';
            document.getElementById('fin-profit').textContent = '0Ä‘';
            document.getElementById('fin-profit-margin').textContent = '0%';
        }

        // Listen for period change
        document.getElementById('financial-period')?.addEventListener('change', function() {
            if (this.value === 'custom') {
                document.getElementById('custom-date-range').classList.remove('hidden');
            } else {
                document.getElementById('custom-date-range').classList.add('hidden');
                loadFinancialReport();
            }
        });

    </script>

    <!-- Search Suggestions -->
    <script src="../js/search-suggestions.js?v=1"></script>
</body>
</html>




