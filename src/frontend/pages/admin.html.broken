                                                <span class="px-3 py-1 rounded-full text-xs font-semibold ${u.trang_thai === 1 ? 'bg-green-500' : 'bg-red-500'}">${u.trang_thai === 1 ? 'âœ“ Hoáº¡t Ä‘á»™ng' : 'âœ— KhÃ³a'}</span>
